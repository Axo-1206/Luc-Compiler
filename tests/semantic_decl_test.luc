package test

-- 1. Global Variables (collected as SymbolKind::Var)
val GLOBAL_CONST int = 100
let mutableVar bool = true

-- 2. Structs (collected as SymbolKind::Struct and children as SymbolKind::Field)
pub struct Point {
    x float
    y float
}

-- 3. Enums (collected as SymbolKind::Enum and children as SymbolKind::EnumVariant)
enum Color {
    Red = 0,
    Green = 1,
    Blue = 2
}

-- 4. Traits (collected as SymbolKind::Trait and children as SymbolKind::Method)
trait Shape {
    area() float
    perimeter() float
}

-- 5. Functions (collected as SymbolKind::Func and children as SymbolKind::Param)
pub val add (a int, b int) int = {
    return a + b
}

-- 6. Implementations (collected as mangled names: Point.move)
impl Point {
    move(dx float, dy float) = {
        -- x and y should be resolved during checkExpr phase
        -- For now, we are testing if Point.move is collected
    }
}

-- 7. Type Aliases (collected as SymbolKind::TypeAlias)
type Distance = float

-- 8. Duplicate Check (uncomment to test error E3005)
-- val GLOBAL_CONST int = 200

-- 8. Entry Point (Required by SemanticAnalyzer)
export imt main () int = {
    -- Use the symbols to ensure they were collected and type-checked
    let p Point = Point{ x = 1.0, y = 2.0 }
    let c Color = Color.Red
    let d Distance = 10.5
    
    -- Calling the collected function
    let sum int = add(10, 20)
}
