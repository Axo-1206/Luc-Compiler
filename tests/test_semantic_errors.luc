package test

-- Test 1: Missing struct field
struct Point {
    x float
    y float
}

-- This should error: missing field y
let p1 Point = Point { }

-- Test 2: Function call with wrong argument count  
const add (a int) (b int) int = {
    return a + b
}

-- This should error: incorrect type, expected (b int) int but got int
let res int = add(5)

-- Test 3: Calling non-callable
let x int = 42
-- This should error: x is not callable
let y int = x()
