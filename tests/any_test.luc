package test

struct Point {
    x int
    y int
}

export const main () int = {
    -- 1. Integer in 'any'
    let val any = 42
    if val is int {
        -- Success: any can hold int
    }

    -- 2. Struct in 'any'
    let p Point = Point { x = 10, y = 20 }
    val = p
    if val is Point {
        -- Success: any can hold struct
    }

    -- 3. Function in 'any'
    const add (a int, b int) int = { 
        return a + b 
    }
    val = add
    if val is (int, int) int {
        -- Success: any can hold function pointer
    }
    
    -- 4. Negative test
    if val is string {
        -- Should not enter
    }
    return 0
}
