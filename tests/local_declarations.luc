-- local_declarations.luc
-- Tests local declarations inside blocks, plus other advanced features
-- from the updated grammar.
package test

-- ============================================================================
-- Top-level declarations for use in local tests
-- ============================================================================

struct GlobalPoint {
    x int
    y int
}

enum GlobalColor {
    Red
    Green
    Blue
}

trait Drawable {
    draw ()
}

impl GlobalPoint : Drawable {
    draw () = { io.printl("GlobalPoint at " + string(x) + "," + string(y)) }
}

type GlobalTransform<T> = (v T) -> T

let globalConst int = 100

-- ============================================================================
-- Main function – contains many local declarations and tests
-- ============================================================================

export const main (args []string) -> int = {
    B and H = 4 
    -- ------------------------------------------------------------------------
    -- Local type alias
    -- ------------------------------------------------------------------------
    type LocalInt = int
    let num LocalInt = 42

    -- ------------------------------------------------------------------------
    -- Local struct
    -- ------------------------------------------------------------------------
    struct LocalVec2 {
        x float
        y float
    }

    let origin LocalVec2 = LocalVec2 { x = 0.0, y = 0.0 }

    -- Local impl for local struct
    impl LocalVec2 {
        length () -> float = {
            return #sqrt(x*x + y*y)
        }
    }
    let len float = origin:length()

    -- ------------------------------------------------------------------------
    -- Local enum
    -- ------------------------------------------------------------------------
    enum LocalDirection {
        North
        South
        East
        West
    }
    let dir LocalDirection = LocalDirection.North

    -- ------------------------------------------------------------------------
    -- Local from block (implicit conversion)
    -- ------------------------------------------------------------------------
    struct LocalMeters { value float }
    struct LocalFeet   { value float }

    from LocalFeet {
        (m LocalMeters) -> LocalFeet = {
            return LocalFeet { value = m.value * 3.28084 }
        }
    }

    let meters LocalMeters = LocalMeters { value = 10.0 }
    let feet LocalFeet = meters   -- implicit conversion

    -- ------------------------------------------------------------------------
    -- Local function with attribute
    -- ------------------------------------------------------------------------
    @inline
    let square (x int) -> int = { return x * x }
    let sq int = square(5)

    -- ------------------------------------------------------------------------
    -- Local use (import) – assuming package 'math' exists
    -- ------------------------------------------------------------------------
    use math as m
    let pi float = m.PI   -- just a placeholder, actual may not exist

    -- ------------------------------------------------------------------------
    -- Multi-assignment (reassignment to existing variables)
    -- ------------------------------------------------------------------------
    let a int, b string = returnsMulti(10)
    a, b = returnsMulti(20)   -- reassignment without let/const

    -- Helper function for multi-return
    let returnsMulti (x int) -> (int, string) = {
        return x * 2, "value: " + string(x)
    }

    -- ------------------------------------------------------------------------
    -- Raw string literals with # delimiters
    -- ------------------------------------------------------------------------
    let raw1 string = r"simple\n\t"                     -- no escapes, literal backslash-n
    let raw2 string = r#"He said "Hello""#              -- contains double quote
    --let raw3 string = r##"Embedded "#" and "##"##       -- contains both " and "# sequences
    let regex string = r"^\d{3}-\d{2}-\d{4}$"           -- regex without escape

    -- ------------------------------------------------------------------------
    -- Catch step (|> catch)
    -- ------------------------------------------------------------------------
    struct LocalError { msg string }
    let riskyDivide (x int, y int) -> (int, LocalError?) = {
        if y == 0 { return 0, LocalError { msg = "division by zero" } }
        return x / y, nil
    }
    let result int = riskyDivide(10, 2) |> (err Error?) {
        io.printl("Error: " + err.msg)
        return -1
    }

    -- ------------------------------------------------------------------------
    -- Safe navigation operator (?.)
    -- ------------------------------------------------------------------------
    struct Container {
        data &GlobalPoint?
    }
    let container Container? = nil
    let coordX int? = container?.data?.x

    -- ------------------------------------------------------------------------
    -- Null coalescing (??)
    -- ------------------------------------------------------------------------
    let maybe int? = nil
    let value int = maybe ?? 100

    -- ------------------------------------------------------------------------
    -- Range slices (.. and ..<)
    -- ------------------------------------------------------------------------
    let dynArr [*]int = [10, 20, 30, 40, 50]
    let inclusive []int = dynArr[1..3]     -- [20,30,40]
    let exclusive []int = dynArr[1..<3]    -- [20,30]

    -- ------------------------------------------------------------------------
    -- For loop with step
    -- ------------------------------------------------------------------------
    let sum int = 0
    for i int in 0..10..2 {
        sum = sum + i
    }

    -- ------------------------------------------------------------------------
    -- While loop
    -- ------------------------------------------------------------------------
    let w int = 0
    while w < 5 {
        w = w + 1
    }

    -- ------------------------------------------------------------------------
    -- Do-while loop
    -- ------------------------------------------------------------------------
    let dw int = 0
    do {
        dw = dw + 1
    } while dw < 3

    -- ------------------------------------------------------------------------
    -- Break and continue
    -- ------------------------------------------------------------------------
    for i int in 0..10 {
        if i % 2 == 0 { continue }
        if i > 7 { break }
        sum = sum + i
    }

    -- ------------------------------------------------------------------------
    -- is type check narrowing
    -- ------------------------------------------------------------------------
    let anything any = 42
    if anything is int {
        let intVal int = anything   -- narrowed
        io.printl("int: " + string(intVal))
    }

    -- ------------------------------------------------------------------------
    -- Match expression with struct pattern and guard
    -- ------------------------------------------------------------------------
    let point GlobalPoint = GlobalPoint { x = 5, y = 10 }
    let desc string = match point {
        GlobalPoint { x: 0, y: 0 } => "origin"
        GlobalPoint { x, y } if x == y => "diagonal"
        GlobalPoint { x, y } => "point (" + string(x) + "," + string(y) + ")"
        default => "unknown"
    }

    -- ------------------------------------------------------------------------
    -- Switch statement
    -- ------------------------------------------------------------------------
    switch point.x {
        case 0: { io.printl("zero") }
        case 1..10: { io.printl("between 1 and 10") }
        case 11..<100: { io.printl("between 11 and 99") }
        default: { io.printl("large") }
    }

    -- ------------------------------------------------------------------------
    -- any type usage
    -- ------------------------------------------------------------------------
    let mixed any = "hello"
    mixed = 123

    -- ------------------------------------------------------------------------
    -- References (&) and reference equality (===)
    -- ------------------------------------------------------------------------
    let original GlobalPoint = GlobalPoint { x = 1, y = 2 }
    let ref p &GlobalPoint = original
    p.x = 100   -- modifies original
    let ref p2 &GlobalPoint = original
    let sameRef bool = p === p2   -- true
    let copy GlobalPoint = original
    let sameVal bool = original === copy   -- false (different addresses)

    -- ------------------------------------------------------------------------
    -- Power operator (^) right-associative
    -- ------------------------------------------------------------------------
    let pow1 int = 2 ^ 3        -- 8
    let pow2 int = 2 ^ 3 ^ 2    -- 2^(3^2)=512

    -- ------------------------------------------------------------------------
    -- Bitwise operators (&&, ||, ~^, ~~, <<, >>)
    -- ------------------------------------------------------------------------
    let flags uint32 = 0b1100
    let mask uint32 = 0b1010
    let andRes uint32 = flags && mask   -- 0b1000
    let orRes  uint32 = flags || mask   -- 0b1110
    let xorRes uint32 = flags ~^ mask   -- 0b0110
    let notRes uint32 = ~~flags         -- bitwise NOT
    let shifted uint32 = flags << 2

    -- ------------------------------------------------------------------------
    -- Assignment operators (all forms)
    -- ------------------------------------------------------------------------
    let x int = 10
    x += 5
    x -= 3
    x *= 2
    x /= 4
    x ^= 2          -- power assignment
    x %= 3
    x &&= 0xFF
    x ||= 0x0F
    x ~^= 0xAA
    x <<= 1
    x >>= 1

    -- ------------------------------------------------------------------------
    -- Pipeline (|>) with ! argument pack
    -- ------------------------------------------------------------------------
    let scaleVec (v GlobalPoint, factor int) -> GlobalPoint = {
        return GlobalPoint { x = v.x * factor, y = v.y * factor }
    }
    let scaled GlobalPoint = original |> scaleVec(2)!

    -- Pipeline with method reference
    impl GlobalPoint {
        getX () -> int = { return x }
    }
    let xVal int = original |> GlobalPoint:getX

    -- Pipeline with anonymous function
    let anonPipe int = 10 |> (n int) -> int { return n + 5 }

    -- ------------------------------------------------------------------------
    -- Composition (+>)
    -- ------------------------------------------------------------------------
    let doubleFn (n int) -> int = { return n * 2 }
    let toStringFn (n int) -> string = { return string(n) }
    let composed (n int) -> string = doubleFn +> toStringFn
    let compResult string = composed(42)

    -- ------------------------------------------------------------------------
    -- Intrinsics
    -- ------------------------------------------------------------------------
    let sz uint64 = #sizeof(GlobalPoint)
    let align uint64 = #alignof(GlobalPoint)
    let sqrtVal float = #sqrt(16.0)
    let floorVal float = #floor(3.7)
    let ceilVal float = #ceil(3.2)
    let roundVal float = #round(3.5)
    let absVal int = #abs(-10)
    let powVal float = #pow(2.0, 3.0)
    let fmaVal float = #fma(2.0, 3.0, 1.0)
    let minVal int = #min(10, 20)
    let maxVal int = #max(10, 20)
    let leading int = #clz(0b00110000)
    let trailing int = #ctz(0b00110000)
    let popcnt int = #popcount(0b110011)
    let swapped int = #bswap(0x12345678)

    -- ------------------------------------------------------------------------
    -- Local const (compile-time constant)
    -- ------------------------------------------------------------------------
    const localConst int = 42
    -- localConst = 10  -- ERROR: const cannot be reassigned (parser accepts? semantic error)

    -- ------------------------------------------------------------------------
    -- @extern usage (raw pointer)
    -- ------------------------------------------------------------------------
    @extern("malloc")
    const malloc (size uint64) -> *uint8?
    let buf *uint8? = malloc(1024)
    if buf != nil {
        let ref &uint8 = #ptrToRef(buf)
        ref = 0xFF
        let next *uint8 = #ptrOffset(buf, 1)
    }

    -- ------------------------------------------------------------------------
    -- from implicit conversion (using top-level from GlobalPoint)
    -- ------------------------------------------------------------------------
    let pt GlobalPoint = pair   -- implicit via from GlobalPoint

    -- ------------------------------------------------------------------------
    -- type alias usage (top-level and local)
    -- ------------------------------------------------------------------------
    let transform GlobalTransform<int> = (v int) -> int { return v * 2 }
    let transformed int = transform(10)

    -- ------------------------------------------------------------------------
    -- Enum variant access (top-level)
    -- ------------------------------------------------------------------------
    let color GlobalColor = GlobalColor.Blue

    -- ------------------------------------------------------------------------
    -- Struct literal with defaults (local struct with defaults)
    -- ------------------------------------------------------------------------
    struct LocalDefaults {
        a int = 1
        b string = "default"
    }
    let def LocalDefaults = LocalDefaults { a = 42 }   -- b uses default

    -- ------------------------------------------------------------------------
    -- Return from main
    -- ------------------------------------------------------------------------
    return 0
}

-- ----------------------------------------------------------------------------
-- Helper function outside main (top-level) – also tests multi-return
-- ----------------------------------------------------------------------------
let helper () -> (int, string) = {
    return 100, "helper"
}

-- Not supported, but consider add it in the future
-- Test that top-level multi-assignment works (only declaration, not reassignment)
-- let topA int, topB string = helper()
