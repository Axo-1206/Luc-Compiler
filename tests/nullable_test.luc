package test

struct Data {
    id int
}

struct Box<T> {
    value T
}

export const main() int = {
    -- 1. Non-nullable assigned with nil (SHOULD ERROR)
    let i int = 1
    i = nil -- Expect E3002: cannot assign nil to non-nullable 'int'

    -- 2. Nullable assigned with nil (SHOULD PASS)
    let b int? = 1
    b = nil -- Valid: int? can be nil

    -- 3. Guarded Usage (SHOULD PASS)
    if b is int {
        let x int = b + 5 -- Valid: b is narrowed to int
    }
    
    -- 4. Unguarded Usage
    let y int = b + 5 -- Expect W3003: Performing operation on nullable type; value may be nil at runtime.

    -- 5. Complex scenario: Struct
    let d Data? = Data { id = 10 }
    d = nil -- Valid

    -- 6. Complex scenario: Generic
    let g Box<int>? = Box<int> { value = 100 }
    g = nil -- Valid

    -- 7. Complex scenario: Function
    let f ((int) int)? = nil -- Valid
    
    return 0
}
